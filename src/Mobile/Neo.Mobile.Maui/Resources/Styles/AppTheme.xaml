<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="AppBackground">#F4F6FB</Color>
    <Color x:Key="CardBackground">#FFFFFF</Color>
    <Color x:Key="Primary">#2563EB</Color>
    <Color x:Key="PrimaryDark">#1D4ED8</Color>
    <Color x:Key="Accent">#0EA5E9</Color>
    <Color x:Key="Success">#10B981</Color>
    <Color x:Key="Warning">#F59E0B</Color>
    <Color x:Key="Danger">#EF4444</Color>
    <Color x:Key="TextPrimary">#111827</Color>
    <Color x:Key="TextSecondary">#6B7280</Color>
    <Color x:Key="Border">#E5E7EB</Color>
    <Color x:Key="Disabled">#D1D5DB</Color>
    <Color x:Key="TileSales">#EEF2FF</Color>
    <Color x:Key="TilePurchase">#F3F4F6</Color>
    <Color x:Key="TileInventory">#F3F4F6</Color>
    <Color x:Key="TileAccounting">#F3F4F6</Color>
    <Color x:Key="TileSettings">#F3F4F6</Color>

    <Style x:Key="PageRoot" TargetType="ContentPage">
        <Setter Property="BackgroundColor" Value="{StaticResource AppBackground}" />
        <Setter Property="FlowDirection" Value="RightToLeft" />
    </Style>

    <Style x:Key="TitleLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="VazirBold" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="SubtitleLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="Vazir" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
    </Style>

    <Style x:Key="FieldLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="VazirMedium" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <Style x:Key="InputEntry" TargetType="Entry">
        <Setter Property="FontFamily" Value="Vazir" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}" />
        <Setter Property="HeightRequest" Value="48" />
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="FontFamily" Value="VazirBold" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="HeightRequest" Value="48" />
        <Setter Property="Padding" Value="16,0" />
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="FontFamily" Value="VazirMedium" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}" />
        <Setter Property="BorderColor" Value="{StaticResource Border}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="HeightRequest" Value="44" />
    </Style>

    <Style x:Key="CardBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}" />
        <Setter Property="Stroke" Value="{StaticResource Border}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="16" />
            </Setter.Value>
        </Setter>
        <Setter Property="Padding" Value="16" />
    </Style>
</ResourceDictionary>
