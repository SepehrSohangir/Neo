{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },
      "stores-route": {
        "ClusterId": "sync-cluster",
        "Match": {
          "Path": "/stores/{**catch-all}"
        },
        "AuthorizationPolicy": "authenticated"
      },
      "sync-route": {
        "ClusterId": "sync-cluster",
        "Match": {
          "Path": "/sync/{**catch-all}"
        },
        "AuthorizationPolicy": "authenticated"
      },
      "products-route": {
        "ClusterId": "sync-cluster",
        "Match": {
          "Path": "/products/{**catch-all}"
        },
        "AuthorizationPolicy": "authenticated"
      },
      "prices-route": {
        "ClusterId": "sync-cluster",
        "Match": {
          "Path": "/prices/{**catch-all}"
        },
        "AuthorizationPolicy": "authenticated"
      },
      "invoices-route": {
        "ClusterId": "sync-cluster",
        "Match": {
          "Path": "/invoices/{**catch-all}"
        },
        "AuthorizationPolicy": "authenticated"
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-service": {
            "Address": "http://auth-api:8080/"
          }
        }
      },
      "sync-cluster": {
        "Destinations": {
          "sync-service": {
            "Address": "http://sync-api:8080/"
          }
        }
      }
    }
  }
}
